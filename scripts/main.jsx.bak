                connections,
                view,
                projectName
            },
            thumbnail
        };

        setProjects(prev => {
            // 如果项目名已存在，覆盖旧的（或者创建副本，这里选择创建新条目）
            return [newProject, ...prev];
        });

        // 显示保存成功提示
        alert(`项目 "${name}" 已保存到历史记录`);
    }, [nodes, connections, view, projectName]);

    // 从历史记录加载项目
    const handleLoadFromHistory = useCallback((project) => {
